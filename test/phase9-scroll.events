# Frame 199: cursor on line 50 (past viewport bottom).
# The viewport should have scrolled to show the cursor.
199 capture /tmp/os-p9-bottom.png
# Cmd+Up: jump to document start (scroll should reset to top).
199 key cmd+up
200 capture /tmp/os-p9-top.png
# Cmd+Down: jump to document end (scroll should jump to bottom).
200 key cmd+down
201 capture /tmp/os-p9-end.png
# Page Up: scroll up by one viewport height.
201 key pageup
202 capture /tmp/os-p9-pageup.png
# Page Down: scroll back down.
202 key pagedown
203 capture /tmp/os-p9-pagedown.png
203 exit
