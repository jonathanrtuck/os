graph LR
    %% Userspace Component Graph — Runtime Communication
    %% Updated 2026-03-30 to reflect v0.5 architecture:
    %%   - "core" decomposed into document + layout + presenter
    %%   - cpu-render and virgil-render removed; metal-render is sole backend
    %%   - New services: store, rich-editor, png-decode
    %%
    %% Shows runtime IPC and shared memory data flow, not compile-time dependencies.
    %% For compile-time dependencies, see dependency-graph.mermaid.
    subgraph Hardware
        KB[Keyboard]
        TABLET[Tablet]
        GPU_HW[GPU / Display]
        BLK_HW[Block Device]
        FS_HW[Host FS]
    end

    subgraph Drivers
        INPUT[virtio-input]
        P9[virtio-9p]
        BLK[virtio-blk]
    end

    subgraph "Document Pipeline"
        PRESENTER[presenter]
        LAYOUT[layout]
        DOCUMENT[document]
    end

    subgraph Editors
        EDITOR[text-editor]
        RICH[rich-editor]
    end

    subgraph Storage
        STORE[store]
    end

    subgraph Rendering
        METAL[metal-render]
    end

    INIT[init]
    PNG[png-decode]

    %% Hardware → Drivers
    KB --> INPUT
    TABLET --> INPUT
    FS_HW --> P9
    BLK_HW --> BLK

    %% Boot: init orchestrates all spawning and IPC wiring
    INIT -.->|spawns + config| INPUT
    INIT -.->|spawns + config| P9
    INIT -.->|spawns + config| BLK
    INIT -.->|spawns + config| PRESENTER
    INIT -.->|spawns + config| LAYOUT
    INIT -.->|spawns + config| DOCUMENT
    INIT -.->|spawns + config| STORE
    INIT -.->|spawns + config| EDITOR
    INIT -.->|spawns + config| RICH
    INIT -.->|spawns + config| METAL
    INIT -.->|spawns + config| PNG
    INIT -->|fonts via Content Region| PRESENTER
    INIT -->|fonts via Content Region| METAL

    %% Runtime data flow (the pipeline)
    INPUT -->|KEY_EVENT, POINTER via state register| PRESENTER
    PRESENTER -->|KEY_EVENT| EDITOR
    PRESENTER -->|KEY_EVENT| RICH
    EDITOR -->|write requests via edit protocol| DOCUMENT
    RICH -->|write requests via edit protocol| DOCUMENT
    PRESENTER <-->|layout requests / results| LAYOUT
    PRESENTER <-->|edit commits, undo/redo| DOCUMENT
    DOCUMENT -->|"persistence: commit, snapshot"| STORE
    STORE -->|block I/O| BLK
    PRESENTER -->|scene graph: shared memory| METAL
    METAL --> GPU_HW
