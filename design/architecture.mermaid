graph TB
    %% System Architecture — Process Layers and IPC
    %% Three layers: Kernel (EL1), OS Service (EL0 trusted), Editors (EL0 untrusted)
    %% Primary IPC: shared memory ring buffers between editors and OS service
    %% Documents: memory-mapped by kernel into both OS service and editors
    %% See: Decision #16 in decisions.md

    subgraph editors["Editors (EL0, untrusted)"]
        direction LR
        E1["Text Editor"]
        E2["Image Editor"]
        E3["Audio Editor"]
    end

    subgraph service["OS Service (EL0, trusted)"]
        direction LR
        RENDER["Renderer"]
        META["Metadata DB"]
        INPUT["Input Router"]
        COMP["Compositor"]
    end

    subgraph kernel["Kernel (EL1)"]
        direction LR
        HANDLE["Handle Tables"]
        MEM["Memory Mgmt"]
        SCHED["Scheduler"]
        VALID["IPC Validator"]
        DRV["Drivers"]
    end

    E1 <-->|"ring buffer channel"| service
    E2 <-->|"ring buffer channel"| service
    E3 <-->|"ring buffer channel"| service

    editors -->|"syscalls (handle ops, channel create)"| kernel
    service -->|"syscalls (document access, display, storage)"| kernel

    MEM -.->|"memory-map document pages"| editors
    MEM -.->|"memory-map document pages"| service

    DRV --- HW["Hardware (CPU, display, storage, input devices)"]
