graph TB
    %% System Architecture — Process Layers and IPC
    %% Updated 2026-03-30 to reflect v0.5 decomposition:
    %%   "core" decomposed into document + layout + presenter
    %%   cpu-render and virgil-render removed; metal-render is sole backend
    %% See: architecture.md, system/DESIGN.md

    subgraph editors["Editors (EL0, untrusted)"]
        direction LR
        E1["Text Editor"]
        E2["Rich Editor"]
    end

    subgraph pipeline["Document Pipeline (EL0)"]
        direction LR
        PRESENTER["Presenter\n(scene graph,\ninput routing)"]
        LAYOUT["Layout Engine\n(text layout,\nword breaking)"]
        DOC["Document\n(sole writer,\npiece table)"]
    end

    subgraph services["Services & Drivers (EL0)"]
        direction LR
        STORE["Store\n(persistence,\nundo/redo)"]
        METAL["metal-render\n(Metal GPU)"]
        INPUT["virtio-input\n(keyboard, pointer)"]
        BLK["virtio-blk"]
    end

    subgraph kernel["Kernel (EL1)"]
        direction LR
        HANDLE["Handle Tables"]
        MEM["Memory Mgmt"]
        SCHED["EEVDF Scheduler"]
    end

    E1 <-->|"edit protocol\n(ring buffer)"| PRESENTER
    E2 <-->|"edit protocol\n(ring buffer)"| PRESENTER

    PRESENTER <-->|"layout requests"| LAYOUT
    PRESENTER <-->|"edits, commits"| DOC
    DOC <-->|"persistence"| STORE
    STORE <-->|"block I/O"| BLK
    INPUT -->|"events, pointer state"| PRESENTER

    PRESENTER -->|"scene graph\n(shared memory)"| METAL

    editors -->|"syscalls (handles, channels)"| kernel
    pipeline -->|"syscalls"| kernel
    services -->|"syscalls"| kernel

    MEM -.->|"memory-map\ndocument pages"| editors
    MEM -.->|"memory-map\ndocument + scene graph"| pipeline

    METAL --- HW["Display"]
    INPUT --- KB["Keyboard / Pointer"]
    BLK --- DISK["Disk"]
