graph TD
    %% Compile-time Dependency Graph (layered DAG)
    %% Updated 2026-03-30 to reflect v0.5 architecture:
    %%   - "core" decomposed into document, layout (service), presenter
    %%   - cpu-render and virgil-render removed; metal-render is sole backend
    %%   - New libraries: piecetable, icons, fs, store
    %%   - New services: store, filesystem, decoders/png
    %%   - New user programs: rich-editor
    %%
    %% UNIVERSAL DEPENDENCIES (omitted from edges for readability):
    %%   Every service and program links sys, ipc, protocol.
    %%   Only non-universal edges are drawn below.
    %%
    %% Edges point downward: consumer → dependency.
    %% No cycles allowed.
    subgraph "Layer 4 — Orchestrator"
        INIT[init]
    end

    subgraph "Layer 3 — Document Pipeline"
        PRESENTER[presenter]
        LAYOUT_SVC["layout ‹service›"]
        DOCUMENT[document]
    end

    subgraph "Layer 3 — Storage"
        STORE_SVC["store ‹service›"]
        FILESYSTEM[filesystem]
    end

    subgraph "Layer 3 — Drivers & Decoders"
        METAL[metal-render]
        V_INPUT[virtio-input]
        V_9P[virtio-9p]
        V_BLK[virtio-blk]
        V_CON[virtio-console]
        PNG[png-decode]
    end

    subgraph "Layer 3 — Editors"
        EDITOR[text-editor]
        RICH_EDITOR[rich-editor]
    end

    subgraph "Layer 2 — Domain Libraries"
        RENDER[render]
        DRAWING[drawing]
        FONTS[fonts]
        SCENE[scene]
        LAYOUT[layout]
        ANIMATION[animation]
        PIECETABLE[piecetable]
        ICONS[icons]
        FS[fs]
        STORE[store]
    end

    subgraph "Layer 1 — Infrastructure Libraries"
        IPC[ipc]
        VIRTIO[virtio]
        PROTOCOL[protocol]
    end

    subgraph "Layer 0 — Foundation"
        SYS[sys]
    end

    %% Orchestrator
    INIT --> SCENE

    %% Document Pipeline (non-universal deps only)
    PRESENTER --> RENDER
    PRESENTER --> DRAWING
    PRESENTER --> FONTS
    PRESENTER --> SCENE
    PRESENTER --> LAYOUT
    PRESENTER --> ANIMATION
    PRESENTER --> PIECETABLE
    PRESENTER --> ICONS

    LAYOUT_SVC --> FONTS
    LAYOUT_SVC --> LAYOUT
    LAYOUT_SVC --> PIECETABLE
    LAYOUT_SVC --> SCENE

    DOCUMENT --> PIECETABLE

    %% Storage
    STORE_SVC --> VIRTIO
    STORE_SVC --> FS
    STORE_SVC --> STORE

    FILESYSTEM --> VIRTIO
    FILESYSTEM --> FS

    %% Render driver
    METAL --> VIRTIO
    METAL --> DRAWING
    METAL --> FONTS
    METAL --> RENDER
    METAL --> SCENE

    %% Virtio drivers (all share: virtio)
    V_INPUT --> VIRTIO
    V_9P --> VIRTIO
    V_BLK --> VIRTIO
    V_CON --> VIRTIO

    %% Editors (non-universal deps only)
    RICH_EDITOR --> PIECETABLE

    %% Library inter-dependencies
    RENDER --> SCENE
    RENDER --> FONTS
    RENDER --> DRAWING
    RENDER --> PROTOCOL
    DRAWING --> FONTS
    DRAWING --> PROTOCOL
    STORE --> FS

    %% Infrastructure → Foundation
    IPC --> SYS
    VIRTIO --> SYS

    %% Domain → Foundation
    SCENE --> SYS
    LAYOUT --> SYS
    ANIMATION --> SYS

    %% Style: highlight shared-across-branches libraries
    style SYS fill:#2a4858,stroke:#4a8898
    style PROTOCOL fill:#2a4858,stroke:#4a8898
    style SCENE fill:#2a4858,stroke:#4a8898
    style FONTS fill:#2a4858,stroke:#4a8898
    style PIECETABLE fill:#2a4858,stroke:#4a8898
